<!--
  Libvirt domain template for the K2s Windows worker VM.
  Users may copy this file to /var/lib/k2s/libvirt/domain.xml.tmpl and
  customise it before running 'k2s install'. When a file exists at that
  path the installer uses it instead of the compiled-in default.

  Available template variables:
    {{.Name}}          - VM name (e.g. "k2s-win-worker")
    {{.MemoryKB}}      - Memory in KiB
    {{.CPUCount}}      - Number of vCPUs
    {{.DiskPath}}      - Absolute path to the QCOW2 disk image
    {{.NetworkBridge}}  - Libvirt network name (e.g. "k2s")
    {{.FirmwarePath}}  - Path to OVMF UEFI firmware image
    {{.NVRAMPath}}     - Path to per-VM EFI variable store
-->
<domain type='kvm'>
  <name>{{.Name}}</name>
  <memory unit='KiB'>{{.MemoryKB}}</memory>
  <currentMemory unit='KiB'>{{.MemoryKB}}</currentMemory>
  <vcpu placement='static'>{{.CPUCount}}</vcpu>

  <os firmware='efi'>
    <type arch='x86_64' machine='q35'>hvm</type>
    <loader readonly='yes' type='pflash'>{{.FirmwarePath}}</loader>
    <nvram>{{.NVRAMPath}}</nvram>
    <boot dev='hd'/>
  </os>

  <features>
    <acpi/>
    <apic/>
    <hyperv mode='custom'>
      <relaxed state='on'/>
      <vapic state='on'/>
      <spinlocks state='on' retries='8191'/>
      <vpindex state='on'/>
      <runtime state='on'/>
      <synic state='on'/>
      <stimer state='on'/>
      <frequencies state='on'/>
      <tlbflush state='on'/>
    </hyperv>
  </features>

  <cpu mode='host-passthrough' check='none' migratable='on'>
    <topology sockets='1' dies='1' cores='{{.CPUCount}}' threads='1'/>
  </cpu>

  <clock offset='localtime'>
    <timer name='hypervclock' present='yes'/>
    <timer name='hpet' present='no'/>
  </clock>

  <on_poweroff>destroy</on_poweroff>
  <on_reboot>restart</on_reboot>
  <on_crash>destroy</on_crash>

  <devices>
    <!-- VirtIO SCSI disk -->
    <disk type='file' device='disk'>
      <driver name='qemu' type='qcow2' discard='unmap'/>
      <source file='{{.DiskPath}}'/>
      <target dev='sda' bus='scsi'/>
    </disk>
    <controller type='scsi' index='0' model='virtio-scsi'/>

    <!-- VirtIO network adapter -->
    <interface type='network'>
      <source network='{{.NetworkBridge}}'/>
      <model type='virtio'/>
    </interface>

    <!-- Serial console for debugging -->
    <serial type='pty'>
      <target port='0'/>
    </serial>
    <console type='pty'>
      <target type='serial' port='0'/>
    </console>

    <!-- VirtIO RNG (random number generator) -->
    <rng model='virtio'>
      <backend model='random'>/dev/urandom</backend>
    </rng>

    <!-- VirtIO balloon for memory management -->
    <memballoon model='virtio'/>

    <!-- Video (QXL for Windows) -->
    <video>
      <model type='qxl' ram='65536' vram='65536' vgamem='16384' heads='1' primary='yes'/>
    </video>

    <!-- Input devices -->
    <input type='tablet' bus='usb'/>
    <input type='keyboard' bus='usb'/>

    <!-- USB controller for input devices -->
    <controller type='usb' index='0' model='qemu-xhci'/>
  </devices>
</domain>
