<!--
  Libvirt network template for K2s host-to-VM communication.
  Users may copy this file to /var/lib/k2s/libvirt/network.xml.tmpl and
  customise it before running 'k2s install'. When a file exists at that
  path the installer uses it instead of the compiled-in default.

  Available template variables:
    {{.Name}}           - Network name (e.g. "k2s")
    {{.BridgeName}}     - Bridge interface name (e.g. "virbr-k2s")
    {{.HostIP}}         - Host-side IP address on the bridge
    {{.Netmask}}        - Network mask
    {{.DHCPRangeStart}} - First DHCP address
    {{.DHCPRangeEnd}}   - Last DHCP address
    {{.WinVMMac}}       - MAC address for the Windows VM (DHCP reservation)
    {{.WinVMIP}}        - Static IP assigned to the Windows VM via DHCP
-->
<network>
  <name>{{.Name}}</name>
  <forward mode='nat'>
    <nat>
      <port start='1024' end='65535'/>
    </nat>
  </forward>
  <bridge name='{{.BridgeName}}' stp='on' delay='0'/>
  <ip address='{{.HostIP}}' netmask='{{.Netmask}}'>
    <dhcp>
      <range start='{{.DHCPRangeStart}}' end='{{.DHCPRangeEnd}}'/>
      <host mac='{{.WinVMMac}}' name='k2s-win-worker' ip='{{.WinVMIP}}'/>
    </dhcp>
  </ip>
</network>
