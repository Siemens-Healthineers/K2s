{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "Prometheus datasource for RTK metrics",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "annotations": {
    "list": []
  },
  "description": "RTK (Rust Token Killer) PoC — Token optimization metrics for K2s development",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "Overview",
      "type": "row"
    },
    {
      "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 50 },
              { "color": "green", "value": 70 }
            ]
          },
          "unit": "percent"
        }
      },
      "gridPos": { "h": 6, "w": 4, "x": 0, "y": 1 },
      "id": 1,
      "options": {
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "title": "Average Token Savings",
      "type": "gauge",
      "targets": [
        {
          "expr": "rtk_savings_percent_avg",
          "legendFormat": "Avg Savings %"
        }
      ]
    },
    {
      "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null }
            ]
          },
          "unit": "short"
        }
      },
      "gridPos": { "h": 6, "w": 4, "x": 4, "y": 1 },
      "id": 2,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "title": "Total Tokens Saved",
      "type": "stat",
      "targets": [
        {
          "expr": "rtk_tokens_saved_total",
          "legendFormat": "Tokens Saved"
        }
      ]
    },
    {
      "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null }
            ]
          },
          "unit": "short"
        }
      },
      "gridPos": { "h": 6, "w": 4, "x": 8, "y": 1 },
      "id": 3,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "title": "Commands Processed",
      "type": "stat",
      "targets": [
        {
          "expr": "rtk_commands_total",
          "legendFormat": "Total Commands"
        }
      ]
    },
    {
      "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.5 },
              { "color": "red", "value": 0.8 }
            ]
          },
          "unit": "percentunit",
          "max": 1
        }
      },
      "gridPos": { "h": 6, "w": 4, "x": 12, "y": 1 },
      "id": 4,
      "options": {
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "showThresholdMarkers": true
      },
      "title": "Compression Ratio (lower = better)",
      "type": "gauge",
      "targets": [
        {
          "expr": "rtk_compression_ratio",
          "legendFormat": "Output/Input"
        }
      ]
    },
    {
      "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null }
            ]
          },
          "unit": "currencyUSD"
        }
      },
      "gridPos": { "h": 6, "w": 4, "x": 16, "y": 1 },
      "id": 5,
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "title": "Estimated Cost Savings",
      "type": "stat",
      "targets": [
        {
          "expr": "rtk_estimated_cost_savings_usd",
          "legendFormat": "USD Saved"
        }
      ]
    },
    {
      "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "text" }
        }
      },
      "gridPos": { "h": 6, "w": 4, "x": 20, "y": 1 },
      "id": 6,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "title": "RTK Status",
      "type": "stat",
      "targets": [
        {
          "expr": "rtk_exporter_up",
          "legendFormat": "Up"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } }, "type": "value" }
          ]
        }
      }
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 7 },
      "id": 101,
      "title": "Token Savings Over Time",
      "type": "row"
    },
    {
      "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 20,
            "showPoints": "auto"
          },
          "unit": "short"
        }
      },
      "gridPos": { "h": 8, "w": 16, "x": 0, "y": 8 },
      "id": 10,
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "title": "Token Volume: Input vs Output",
      "type": "timeseries",
      "targets": [
        {
          "expr": "rtk_tokens_input_total",
          "legendFormat": "Input Tokens (raw)"
        },
        {
          "expr": "rtk_tokens_output_total",
          "legendFormat": "Output Tokens (compressed)"
        },
        {
          "expr": "rtk_tokens_saved_total",
          "legendFormat": "Tokens Saved"
        }
      ]
    },
    {
      "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 10
          },
          "unit": "percent",
          "min": 0,
          "max": 100
        }
      },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 8 },
      "id": 11,
      "title": "Savings % Trend",
      "type": "timeseries",
      "targets": [
        {
          "expr": "rtk_savings_percent_avg",
          "legendFormat": "Avg Savings %"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 16 },
      "id": 102,
      "title": "Command Breakdown",
      "type": "row"
    },
    {
      "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "short"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 17 },
      "id": 20,
      "options": {
        "legend": { "displayMode": "table", "placement": "right" },
        "pieType": "donut",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "title": "Commands by Type",
      "type": "piechart",
      "targets": [
        {
          "expr": "rtk_command_count_total",
          "legendFormat": "{{command_type}}"
        }
      ]
    },
    {
      "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "short"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 17 },
      "id": 21,
      "options": {
        "legend": { "displayMode": "table", "placement": "right" },
        "pieType": "donut",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "title": "Tokens Saved by Command Type",
      "type": "piechart",
      "targets": [
        {
          "expr": "rtk_command_savings_tokens",
          "legendFormat": "{{command_type}}"
        }
      ]
    },
    {
      "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": {
        "defaults": {
          "custom": {
            "displayMode": "lcd",
            "showValue": "always"
          },
          "unit": "short"
        }
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 25 },
      "id": 22,
      "options": {
        "displayMode": "lcd",
        "orientation": "horizontal",
        "showUnfilled": true,
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "title": "Top Optimized Commands (Tokens Saved)",
      "type": "bargauge",
      "targets": [
        {
          "expr": "topk(10, rtk_command_savings_tokens)",
          "legendFormat": "{{command_type}}"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 33 },
      "id": 103,
      "title": "System Info",
      "type": "row"
    },
    {
      "datasource": "${DS_PROMETHEUS}",
      "gridPos": { "h": 4, "w": 24, "x": 0, "y": 34 },
      "id": 30,
      "options": {
        "showHeader": true,
        "sortBy": [{ "displayName": "version" }]
      },
      "title": "RTK Installation Info",
      "type": "table",
      "targets": [
        {
          "expr": "rtk_info",
          "legendFormat": "",
          "format": "table",
          "instant": true
        }
      ],
      "transformations": [
        {
          "id": "labelsToFields",
          "options": {}
        }
      ]
    }
  ],
  "schemaVersion": 38,
  "tags": ["rtk", "poc", "token-optimization", "k2s"],
  "templating": { "list": [] },
  "time": { "from": "now-7d", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "RTK PoC — Token Optimization (K2s)",
  "uid": "rtk-poc-k2s",
  "version": 1
}

