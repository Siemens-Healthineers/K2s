        "localPath": "plugins/cert-manager-0.1.1.tar.gz",
        "sha256": "2b06caae0a207e2c30ce0d21bc4d672ae0a71a2cffc23a4585199110533032ab"
      }
    },
    {
      "name": "prometheus",
      "pluginDir": "prometheus-plugin",
      "version": "0.9.0",
